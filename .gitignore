# ============================================================
# Prevents accidental commit of env files, build artifacts,
# and local development state.
# ============================================================

# ---------- Env files (NEVER commit) ----------
.env
.env.*
!.env.example
.env.local
.env.development
.env.production
.env.staging
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.csr
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
.ssh/
.gnupg/
.aws/
.gcp/
.credentials/
credentials.json
service-account.json
firebase-adminsdk-*.json

# ---------- Local storage / cache / build artifacts ----------
.next/
out/
dist/
build/
.cache/
.turbo/
*.tsbuildinfo

# ---------- Dependencies ----------
node_modules/
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# ---------- Editor / IDE state ----------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ---------- Logs ----------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
logs/

# ---------- Test / coverage output ----------
coverage/
.nyc_output/
*.lcov
test-results/
playwright-report/
playwright/.cache/

# ---------- Local database / runtime data ----------
*.db
*.sqlite
*.sqlite3
db/*.db
prisma/*.db

# ---------- Local scripts ----------
scripts/
tool-results/
agent-ctx/
.scratch/
.tmp/
tmp/

# ---------- OS / misc ----------
.DS_Store
.AppleDouble
.LSOverride
ehthumbs.db
$RECYCLE.BIN/
Network Trash Folder/
Temporary Items/

# ---------- Misc project files ----------
*.local
.local
