# ============================================================
# SECURITY-FIRST .gitignore
# Prevents accidental commit of secrets, env files, build
# artifacts, and local development state.
# ============================================================

# ---------- Secrets & credentials (NEVER commit) ----------
.env
.env.*
!.env.example
.env.local
.env.development
.env.production
.env.staging
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.csr
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
.ssh/
.gnupg/
.aws/
.gcp/
.credentials/
credentials.json
service-account.json
firebase-adminsdk-*.json

# ---------- Local storage / cache / build artifacts ----------
.next/
out/
dist/
build/
.cache/
.turbo/
*.tsbuildinfo

# ---------- Dependencies ----------
node_modules/
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# ---------- Editor / IDE state ----------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ---------- Logs ----------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
logs/

# ---------- Test / coverage output ----------
coverage/
.nyc_output/
*.lcov
test-results/
playwright-report/
playwright/.cache/

# ---------- Local database / runtime data ----------
*.db
*.sqlite
*.sqlite3
db/*.db
prisma/*.db

# ---------- Tool-results / agent-ctx / scratch (dev-only) ----------
tool-results/
agent-ctx/
.scratch/
.tmp/
tmp/

# ---------- OS / misc ----------
.DS_Store
.AppleDouble
.LSOverride
ehthumbs.db
$RECYCLE.BIN/
Network Trash Folder/
Temporary Items/

# ---------- Deployment scripts that may contain tokens ----------
# These contain the obfuscated GitHub token chunks and MUST stay local-only.
# They are never pushed to the public repo (even after going private).
scripts/deploy-gh-pages.js
scripts/harden-public-repo.js
scripts/migrate-vault-encryption.py
scripts/deploy-cssbesthub.sh
scripts/icon-preview.py
scripts/*-local.js
scripts/local-*.sh

# ---------- Misc project files ----------
*.local
.local
